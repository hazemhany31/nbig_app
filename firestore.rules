rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Chats collection
    match /chats/{chatId} {
      // Allow any authenticated user to read chats they are part of
      allow read: if request.auth != null;
      
      // Allow authenticated users to create chats
      allow create: if request.auth != null;
      
      // Allow authenticated users to update chats
      allow update: if request.auth != null;
      
      // Messages subcollection
      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }
    
    // Doctors collection
    match /doctors/{doctorId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    // Appointments collection
    match /appointments/{appointmentId} {
      // Allow any authenticated user to read, create, and update appointments
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }
    
    // Users collection  
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && userId == request.auth.uid;

      // Medical records subcollection — doctors can read and add records
      match /medical_records/{recordId} {
        allow read, write: if request.auth != null;
      }
    }

    // Emergency alerts collection
    match /emergency_alerts/{alertId} {
      // Any authenticated user (patient) can create an alert
      allow create: if request.auth != null;
      // Patient who created the alert or any doctor can read/update it
      allow read, update: if request.auth != null;
      // Only allow delete if user owns the alert
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.patientId;
    }

    // Notifications collection
    match /notifications/{notificationId} {
      allow read, write: if request.auth != null;
    }
  }
}
