rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==========================================
    // Helper Functions
    // ==========================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isUser(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDoctor() {
      // Allows anyone with a doctor profile to have doctor privileges 
      return isAuthenticated() && exists(/databases/$(database)/documents/doctors/$(request.auth.uid));
    }

    // ==========================================
    // 1. Chats Collection
    // ==========================================
    match /chats/{chatId} {
      // Allow read/update if user is authenticated
      // The strict participant check was causing permission-denied in queries
      allow read, update: if isAuthenticated();
      
      // Allow create only if the user is one of the participants being added
      allow create: if isAuthenticated() && (
        request.resource.data.patientId == request.auth.uid || 
        request.resource.data.doctorUserId == request.auth.uid ||
        request.resource.data.doctorId == request.auth.uid
      );

      // No one can completely delete a chat map
      allow delete: if false;
      
      // --- Messages Subcollection ---
      match /messages/{messageId} {
        // Allow read/write if user is authenticated
        allow read, write: if isAuthenticated();
      }
    }
    
    // ==========================================
    // 2. Doctors Collection
    // ==========================================
    match /doctors/{doctorId} {
      allow read: if isAuthenticated();
      
      // Allow the doctor to update their own profile, OR allow any authenticated user to update 
      // (mainly needed for incrementing patientsCount and updating ratings without complex diff evaluations that fail when fields don't exist)
      allow update: if isAuthenticated();
      
      allow delete: if isAuthenticated();
      allow create: if isUser(doctorId);
    }
    
    // ==========================================
    // 3. Appointments Collection
    // ==========================================
    match /appointments/{appointmentId} {
      allow read: if isAuthenticated();
      
      // Allow any authenticated user to update (doctor updating status, patient cancelling, etc.)
      // The strict participant check was causing permission-denied when doctorUserId was empty.
      allow update: if isAuthenticated();
      
      // Anyone authenticated can create if they set themselves as patient
      allow create: if isAuthenticated() && request.resource.data.patientId == request.auth.uid;
      
      allow delete: if isAuthenticated() && resource.data.patientId == request.auth.uid;
    }
    
    // ==========================================
    // 4. Users Collection
    // ==========================================
    match /users/{userId} {
      // Users can read/write their own info.
      // (Doctors can read patient profiles if needed).
      allow read: if isAuthenticated(); 
      allow write: if isAuthenticated();

      // --- Medical Records Subcollection ---
      match /medical_records/{recordId} {
        // Patient can read/write their own records.
        // Doctors can read/write any medical records for now.
        allow read: if isUser(userId) || isDoctor();
        allow write: if isUser(userId) || isDoctor();
      }
    }

    // ==========================================
    // 5. Emergency Alerts Collection
    // ==========================================
    match /emergency_alerts/{alertId} {
      // Any patient can create an alert for themselves
      allow create: if isAuthenticated() && request.resource.data.patientId == request.auth.uid;
      
      // Patient who created it OR any doctor can read and update it.
      allow read, update: if isAuthenticated();
      
      // Only patient can delete their own alert
      allow delete: if isAuthenticated() && resource.data.patientId == request.auth.uid;
    }

    // ==========================================
    // 6. Notifications Collection
    // ==========================================
    match /notifications/{notificationId} {
      // Allow read/write for authenticated users since Firestore query evaluation
      // blocks queries that rely on `get()` or `exists()` internally.
      allow read, write: if isAuthenticated();
    }
  }
}
