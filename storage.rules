rules_version = '2';

// Firebase Storage Security Rules
service firebase.storage {
  match /b/{bucket}/o {
    
    // Profile Images - Users can upload their own profile images
    match /profile_images/{userId}/{allPaths=**} {
      // Anyone logged in can read profile images
      allow read: if request.auth != null;
      
      // Users can only write to their own profile image folder
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Medical Records Uploads - Users can upload their own medical records
    match /uploads/{userId}/{allPaths=**} {
      // Allow read if user is the owner
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // Allow write if user is the owner
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Doctor Profile Images and Clinic Photos
    match /doctors/{allPaths=**} {
      allow read: if true; // anyone can see doctor photos
      allow write: if request.auth != null; // authenticated doctors can upload their photos
    }
  }
}
